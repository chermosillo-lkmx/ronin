# Copia este archivo a `.env` (en server/) y pega tu token de ClickUp.
# `.env` está en .gitignore — nunca se commitea.

# Token personal de ClickUp (Settings → ClickUp API → API Token → Copy)
COWORK_CLICKUP_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcionales:
# COWORK_CLICKUP_TEAM_ID=
# COWORK_CLICKUP_LIST_IDS=123456789,987654321
# COWORK_CLICKUP_REFRESH_MS=60000
